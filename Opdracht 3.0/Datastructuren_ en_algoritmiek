from abc import ABC, abstractmethod

class LinkedList(ABC):
    @abstractmethod
    def toString(self): pass
    @abstractmethod
    def addFirst(self, value): pass
    @abstractmethod
    def remove(self, value): pass
    @abstractmethod
    def smallest(self): pass
    @abstractmethod
    def sortSimple(self): pass
    @abstractmethod
    def isEmpty(self): pass

class Empty(LinkedList):
    def toString(self): return ""
    def addFirst(self, value): return Populated(value, self)
    def remove(self, value): return self
    def smallest(self): return float('inf') # Oneindig groot om vergelijking niet te storen
    def sortSimple(self): return self
    def isEmpty(self): return True

class Populated(LinkedList):
    def __init__(self, value, tail):
        self.value = value
        self.tail = tail # Dit is weer een LinkedList (Empty of Populated)

    def isEmpty(self): return False

    # 2. toString
    def toString(self):
        return f"{self.value} {self.tail.toString()}"

    # 3. addFirst
    def addFirst(self, value):
        return Populated(value, self)

    # 4. remove (verwijdert alleen de eerste instantie)
    def remove(self, value):
        if self.value == value:
            return self.tail
        else:
            return Populated(self.value, self.tail.remove(value))

    # 5. smallest
    def smallest(self):
        tail_smallest = self.tail.smallest()
        return self.value if self.value < tail_smallest else tail_smallest

    # 6. sortSimple (Selection Sort principe)
    def sortSimple(self):
        low = self.smallest()
        remaining = self.remove(low)
        return Populated(low, remaining.sortSimple())
    
    # 8. uniq (telt unieke elementen in een GESORTEERDE lijst)
    def uniq(self):
        if self.tail.isEmpty():
            return 1
        # Omdat het gesorteerd is, hoeven we alleen naar de buurman te kijken
        current_count = 0 if self.value == self.tail.value else 1
        return current_count + self.tail.uniq()
    
